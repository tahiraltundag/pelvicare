{
  "name": "pelvicair-server",
  "version": "1.0.0",
  "description": "PelvicAir API Server",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch index.js",
    "start": "node index.js",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node utils/seed.js",
    "db:studio": "npx prisma studio",
    "setup": "npm install && npx prisma db push && node utils/seed.js",
    "postinstall": "npx prisma generate",
    "vercel-build": "npx prisma db push --accept-data-loss && node utils/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
