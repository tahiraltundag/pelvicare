generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  password         String
  name             String
  role             String            @default("user")
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  orders           Order[]
  refreshTokens    RefreshToken[]
  clinicianProfile ClinicianProfile?
}

model Product {
  id                String      @id @default(cuid())
  name              String
  slug              String      @unique
  description       String      @default("")
  price             Float
  comparePrice      Float?
  categoryId        String?
  category          Category?   @relation(fields: [categoryId], references: [id])
  tags              String      @default("[]")
  images            String      @default("[]")
  stock             Int         @default(0)
  lowStockThreshold Int         @default(5)
  variants          String      @default("[]")
  status            String      @default("taslak")
  deletedAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  orderItems        OrderItem[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  products Product[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  status    String      @default("beklemede")
  total     Float
  items     OrderItem[]
  address   String      @default("{}")
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  price     Float
  quantity  Int
  variant   String?
}

model CmsContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @default("")
  type      String   @default("text")
  label     String   @default("")
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ClinicianProfile {
  id          String             @id @default(cuid())
  userId      String             @unique
  user        User               @relation(fields: [userId], references: [id])
  specialty   String             @default("")
  license     String             @default("")
  institution String             @default("")
  phone       String             @default("")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  patients    ClinicianPatient[]
}

model ClinicianPatient {
  id          String           @id @default(cuid())
  clinicianId String
  clinician   ClinicianProfile @relation(fields: [clinicianId], references: [id])
  name        String
  email       String           @default("")
  birthYear   Int?
  gender      String           @default("")
  diagnosis   String           @default("")
  notes       String           @default("")
  createdAt   DateTime         @default(now())
  sessions    PatientSession[]
}

model PatientSession {
  id        String           @id @default(cuid())
  patientId String
  patient   ClinicianPatient @relation(fields: [patientId], references: [id])
  protocol  String
  date      DateTime         @default(now())
  duration  Int              @default(20)
  notes     String           @default("")
  createdAt DateTime         @default(now())
}

model BulkOrderRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  institution String
  phone       String   @default("")
  quantity    Int      @default(1)
  message     String   @default("")
  status      String   @default("beklemede")
  createdAt   DateTime @default(now())
}
